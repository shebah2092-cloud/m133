#!/bin/sh
#
# @name M130 Rocket MPC  (MPC+MHE via acados - SITL)
#
# @type Rocket
#
# @maintainer Rocket GNC Team
#
# Physics engine : 6DOF_v4_pure  (propulsion + aerodynamics + mass model)
# Controller     : PX4 rocket_mpc  (MPC + MHE + LOS guidance via acados)
# Protocol       : MAVLink HIL  (HIL_SENSOR / HIL_GPS / HIL_ACTUATOR_CONTROLS)
# Runner         : 6DOF_v4_pure/rocket_6dof_sim.py
#
# Parameters tuned for Qabthah1 rocket model:
#   mass_full=12.74 kg, mass_dry=11.11 kg
#   Launch: 16.457°N 44.115°E  alt=1200 m MSL
#

. ${R}etc/init.d/rc.rocket_defaults

# ---- Select MPC controller ----
set ROCKET_APP rocket_mpc

# HIL mode - all sensor data comes from 6DOF sim bridge
param set-default SYS_HITL 1

# GPS simulator is enabled by default for SITL/HITL (SENS_EN_GPSSIM=1).
# It feeds from EKF2 global position to generate simulated GPS output.
# The MHE sensor_bridge reads vehicle_gps_position (blended GPS output).

# In SITL we want controller/debug visibility instead of irreversible PX4
# termination, which otherwise cuts actuator output and ends the TCP session.
param set CBRK_FLIGHTTERM 121212

# ---- Rocket MPC parameters ----
# These are the subset of ROCKET_* params used by RocketMPC module.
# MPC internals (weights, horizons, propulsion model) are hardcoded
# in mpc_controller.cpp to match the acados OCP code-generated solver.

# Control start delay after launch detection (s)
param set-default ROCKET_T_CTRL      0.2

# Target X (downrange, m) uses ROCKET_XTRGT default from rocket_mpc_params.c.

# Fin deflection limit is baked into the acados solver (20° = 0.349 rad).
# To change it, modify m130_ocp_setup.py::delta_max and regenerate the solver.

# SITL GPS fallback — use EKF2 local position as GPS substitute
param set-default ROCKET_SITL_GPS  1
